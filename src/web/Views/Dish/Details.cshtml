@model DishOrderModel

<strong><h2 style="width: max-content;">@Model.DishDto.Name</p></strong>
<p>@Model.DishDto.Description</p>

<form asp-controller="Order" asp-action="AddOrder">
    <input type="hidden" name="OrderItems[0].DishID" value="@Model.DishDto.Id" />

    <div class="mb-3">
        <label class="form-label">Antal</label>
        <button type="button" onclick="changeQuantity(-1)" class="btn btn-outline-secondary">-</button>
        
        <span id="quantityDisplay">1</span>
       
        <button type="button" onclick="changeQuantity(+1)" class="btn btn-outline-secondary">+</button>
        <input type="hidden" name="OrderItems[0].quantity" id="quantity" value="1" />
        
        <p>Pris: <span id="totalPrice">@Model.DishDto.Price</span> kr </p>
    </div>
    
    <h4>Dina uppgifter</h4>
    <div class="mb-3">
        <input type="text" name="Customer.Name" placeholder="Namn" class="form-control mb-2" />
        <span class="text-danger">@Html.ValidationMessage("Customer.Name")</span>

        <input type="text" name="Customer.PhoneNum" placeholder="Telefon" class="form-control mb-2" />
        <span class="text-danger">@Html.ValidationMessage("Customer.PhoneNum")</span>
       
        <input type="email" name="Customer.Email" placeholder="Email" class="form-control mb-2" />
        <span class="text-danger">@Html.ValidationMessage("Customer.Email")</span>
    </div>
    
    <button type="submit" class="btn btn-primary">Lägg till</button>
    <a asp-controller="Restaurant" asp-action="Details" asp-route-id="@Model.DishDto.RestaurantID" class="btn btn-outline-secondary">Tillbaka</a>

</form>

<script> // Jag förstår koden samtidigt som jag inte förstår. Detta är rakt av AI
    const price = @Model.DishDto.Price;
    let quantity = 1;

    function changeQuantity(change) {
        quantity = Math.max(1, Math.min(25, quantity + change));
        document.getElementById("quantity").value = quantity;
        document.getElementById("quantityDisplay").innerText = quantity;
        document.getElementById("totalPrice").innerText = price * quantity;
    }
</script>